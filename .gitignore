# --- dbt + DuckDB ---
target/
dbt_packages/
logs/
*.duckdb
*.duckdb.wal
*.duckdb.tmp

# Real profile must never be committed (kit lesson L1).
profiles.yml

# Raw + intermediate downloads.
# NOTE: we deliberately don't ignore the whole `data/` directory because
# that would block the dashboard warehouse exception below — git won't
# re-include a file inside an ignored directory.
data/raw/
data/*.csv
data/*.parquet

# EXCEPTION: the slim dashboard warehouse IS committed so Streamlit Cloud can
# load it without rebuilding the full pipeline on cold start. Built by
# scripts/build_dashboard_db.py from the full warehouse — only ~700 rows
# total across the three rpt_* tables, well under GitHub's 100MB hard limit.
# The leading `*.duckdb` rule (above) ignores it; this rule re-includes it.
!data/dashboard.duckdb
# Slim decision extract (scores + per-area facts) read by the renter app (app/).
!data/decision.duckdb

# Built dbt docs site (published to Pages from CI).
docs/

# --- Python ---
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Jupyter / Streamlit ---
.ipynb_checkpoints/
.streamlit/secrets.toml

# --- IDE / OS noise ---
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Secrets ---
.env
.env.local
*.pem
