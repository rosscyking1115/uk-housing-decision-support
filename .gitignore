# --- dbt + DuckDB ---
target/
dbt_packages/
logs/
*.duckdb
*.duckdb.wal
*.duckdb.tmp

# Real profile must never be committed (kit lesson L1).
profiles.yml

# Raw + intermediate downloads.
# NOTE: we deliberately don't ignore the whole `data/` directory because
# that would block the dashboard warehouse exception below — git won't
# re-include a file inside an ignored directory.
data/raw/
data/*.csv
data/*.parquet

# EXCEPTION: the slim dashboard warehouse IS committed so Streamlit Cloud can
# load it without rebuilding the full pipeline on cold start. Built by
# scripts/build_dashboard_db.py from the full warehouse — only ~700 rows
# total across the three rpt_* tables, well under GitHub's 100MB hard limit.
# The leading `*.duckdb` rule (above) ignores it; this rule re-includes it.
!data/dashboard.duckdb
# Slim decision extract (scores + per-area facts) read by the renter app (app/).
!data/decision.duckdb

# Built dbt docs site (published to Pages from CI).
docs/
# Source ADRs are reviewed repository records, not generated dbt documentation.
!docs/
!docs/adr/
!docs/adr/ADR-001-area-market-metric-contract.md

# --- Dagster ---
# `dagster dev` scratch home when DAGSTER_HOME is unset (auto-removed on clean exit).
.tmp_dagster_home_*/
.dagster/

# --- Python ---
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Jupyter / Streamlit ---
.ipynb_checkpoints/
.streamlit/secrets.toml

# --- IDE / OS noise ---
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Secrets ---
.env
.env.local
*.pem

# internal working docs — kept local, not for the public repo
/HOUSING_DECISION_SUPPORT_BUILD_PLAN.md
/PROJECT-2-KIT.md
/PROJECT_AUDIT_AND_HOUSING_FIT.md
/UK_COVERAGE_EXPANSION_PLAN.md
/PRODUCT_ROADMAP.md
/PROJECT_PLAYBOOK.md
/SCOTLAND_DISCOVERY_SPIKE.md
/mobile/DESIGN_HANDOFF.md

# Local editor/agent session config.
.claude/
