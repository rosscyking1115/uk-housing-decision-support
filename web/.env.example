# Base URL of the public FastAPI v2 service (api/). Used server-side only.
# Local dev: run the API with `uvicorn api.main:app --reload` (defaults to :8000).
API_BASE_URL=http://127.0.0.1:8000

# Public canonical site origin (no trailing slash). Used for metadata, sitemap, JSON-LD.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# The search map uses MapLibre GL JS with OpenFreeMap's public tile service.
# It needs no account, API key, billing setup, or map environment variables.
