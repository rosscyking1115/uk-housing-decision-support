# Base URL of the Phase 1 FastAPI service (api/). Used server-side only.
# Local dev: run the API with `uvicorn api.main:app --reload` (defaults to :8000).
API_BASE_URL=http://127.0.0.1:8000

# Public canonical site origin (no trailing slash). Used for metadata, sitemap, JSON-LD.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Maps JavaScript API key (search map). Exposed to the browser — secure it
# with HTTP referrer restrictions + the Maps JavaScript API in Google Cloud, not
# by hiding it. Without it, the search page still works; the map shows a prompt.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional Map ID from Google Cloud → Map Management. Enables Advanced Markers and
# cloud map styling. Falls back to Google's DEMO_MAP_ID when unset.
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
